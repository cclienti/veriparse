{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-release",
      "displayName": "Windows MSVC Release (vcpkg)",
      "description": "Build with MSVC and vcpkg-supplied deps. Used by CI and recommended for Windows development. Requires VCPKG_ROOT set in the environment (e.g. via lukka/run-vcpkg in CI, or your own checkout locally).",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true },
      "filter": { "include": { "label": "unittest" } },
      "execution": { "jobs": 4 }
    }
  ],
  "workflowPresets": [
    {
      "name": "windows-release",
      "displayName": "Windows MSVC Release (configure + build + test)",
      "steps": [
        { "type": "configure", "name": "windows-release" },
        { "type": "build",     "name": "windows-release" },
        { "type": "test",      "name": "windows-release" }
      ]
    }
  ]
}
